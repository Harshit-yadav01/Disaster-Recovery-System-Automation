# ---------------------------------------------------------------------------
# HPE DR Automation - backend configuration
# Copy this file to ".env" and adjust the values for your environment.
# ---------------------------------------------------------------------------

# App
APP_ENV=development

# JWT auth
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Dashboard login credentials (demo auth).
# The password is stored as plain text here for local use only.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# CORS - comma separated list of allowed origins for the frontend.
# Leave the default if you open the dashboard from the same server.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500

# ---------------------------------------------------------------------------
# Storage backend
#   simulated -> returns realistic demo data (no array needed)
#   alletra   -> talks to real HPE Alletra Storage MP arrays over WSAPI (:443)
# ---------------------------------------------------------------------------
STORAGE_PROVIDER=simulated

# Real array connection (only used when STORAGE_PROVIDER=alletra).
# Enter the two management IP addresses you received. Do NOT add a port -
# the backend connects over WSAPI (https, port 443) automatically.
ALLETRA_PRIMARY_BASE_URL=10.0.0.11
ALLETRA_RECOVERY_BASE_URL=10.0.0.12

# Same login is used for both arrays.
ALLETRA_USERNAME=your-array-username
ALLETRA_PASSWORD=your-array-password

# Leave false for self-signed array certificates (typical on-array certs).
# Connecting by IP with a self-signed cert works with this off.
ALLETRA_VERIFY_SSL=false
# More secure alternative for self-signed certs: give the path to the array's
# certificate (PEM) and TLS is verified against it instead of disabled.
# Example: ALLETRA_CA_CERT=C:\certs\alletra-mp.pem   (leave blank to skip)
ALLETRA_CA_CERT=
# Seconds before an array request times out.
ALLETRA_TIMEOUT=15
